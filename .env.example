# Copy to .env and fill in. NEVER commit a real .env.

# --- App ---
APP_NAME=Arovolife
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_TIMEZONE=Asia/Kolkata
APP_LOCALE=en

# --- Logging ---
LOG_CHANNEL=stack
LOG_LEVEL=debug
LOG_PII_SCRUB=true

# --- Database (matches docker/docker-compose.yml) ---
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=arovolife
DB_USERNAME=arovolife
DB_PASSWORD=secret

# --- Cache + queue ---
CACHE_DRIVER=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=120
QUEUE_CONNECTION=database     # Phase 1 uses DB; later phases may use Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Mail (Mailpit in dev, SES in prod) ---
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="no-reply@arovolife.example"
MAIL_FROM_NAME="${APP_NAME}"

# --- KYC providers (decisions D-06, D-07 from PRD §16) ---
KYC_PAN_PROVIDER=stub          # stub | karza | idfy | signzy
KYC_PAN_API_URL=
KYC_PAN_API_KEY=
KYC_AADHAAR_PROVIDER=stub      # stub | <UIDAI-approved AUA/KUA>
KYC_AADHAAR_API_URL=
KYC_AADHAAR_API_KEY=
KYC_AADHAAR_LICENCE_KEY=
KYC_BANK_PENNYDROP_PROVIDER=stub
KYC_BANK_PENNYDROP_URL=
KYC_BANK_PENNYDROP_KEY=

# --- SMS / WhatsApp (decision D-05) ---
SMS_PROVIDER=stub              # stub | msg91 | gupshup | karix
SMS_API_KEY=
SMS_SENDER_ID=AROVOL
WHATSAPP_PROVIDER=stub
WHATSAPP_API_KEY=

# --- File storage (KYC documents) ---
FILESYSTEM_DISK=local          # local | s3 (prod = s3 in ap-south-1)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=ap-south-1
AWS_BUCKET=arovolife-kyc
AWS_USE_PATH_STYLE_ENDPOINT=false

# --- Encryption (rotated yearly; key id stored alongside ciphertext) ---
KYC_ENCRYPTION_KEY_ID=v1
KYC_ENCRYPTION_KEY=            # base64-encoded 32-byte key

# --- Auth ---
MFA_REQUIRED_FOR_DISTRIBUTORS=true
MFA_REQUIRED_FOR_ADMINS=true
PASSWORD_MIN_LENGTH=12
PASSWORD_HIBP_CHECK=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# --- Placement Strategy default at launch (decision D-01) ---
# This seeds the settings table on first migrate.
PLACEMENT_DEFAULT_SIDE=default_left   # default_left | default_right | custom
PLACEMENT_ALLOW_SPONSOR_OVERRIDE=true # decision D-02

# --- Cooling-off ---
COOLING_OFF_DAYS=30
COOLING_OFF_REMINDERS_DAYS=20,7,1

# --- State-aware age rule ---
AGE_DEFAULT=18
AGE_MAHARASHTRA=21

# --- Observability ---
OTEL_SERVICE_NAME=arovolife-app
OTEL_EXPORTER_OTLP_ENDPOINT=
PROMETHEUS_METRICS_ENABLED=true
